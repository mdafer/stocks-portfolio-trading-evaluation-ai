# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./data/stock_eval.db

# Stock APIs
# Real-time quotes: Yahoo Finance (no key required)
# Sector stocks: Curated list (~1300 stocks) + Finnhub (optional for enrichment)
FMP_API_KEY=your-fmp-api-key
FINNHUB_API_KEY=your-finnhub-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
